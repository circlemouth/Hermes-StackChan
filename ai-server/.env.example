PORT=8765
STACKCHAN_CONTROL_PORT=8766
STACKCHAN_CONTROL_HOST=127.0.0.1
STACKCHAN_WS_KEEPALIVE_MS=3000

# Connect to an already-running Hermes Dashboard/TUI on the same host.
HERMES_CONNECT_MODE=dashboard_ws
HERMES_DASHBOARD_URL=http://127.0.0.1:9119
# HERMES_DASHBOARD_TOKEN=
HERMES_TURN_TIMEOUT_MS=600000

# HermesAgent root/Python are still used for STT/TTS helper modules and
# as the fallback LLM transport when HERMES_CONNECT_MODE is not dashboard_ws.
HERMES_ROOT=../hermes-agent
HERMES_PYTHON=python3
