# For local OpenAI-compatible LLM servers such as Ollama, LM Studio, llama.cpp, or vLLM,
# OPENAI_API_KEY can be omitted; ai-server will use a local placeholder key.
OPENAI_API_KEY=local
OPENAI_MODEL=qwen2.5:7b
OPENAI_BASE_URL=http://localhost:11434/v1

# Local Whisper ASR service, for example onerahmet/openai-whisper-asr-webservice.
STT_BASE_URL=http://localhost:9000

# Local VOICEVOX Engine.
VOICEVOX_URL=http://localhost:50021
VOICEVOX_SPEAKER=1

PORT=8765
SYSTEM_PROMPT=あなたはStackChanという小さなロボットです。明るく元気に日本語で話します。
