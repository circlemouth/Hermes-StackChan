+void EspSsl::WaitForReceiveTaskExit() {
+    if (receive_task_handle_ == nullptr || event_group_ == nullptr) {
+        return;
+    }
+
+    if (xTaskGetCurrentTaskHandle() == receive_task_handle_) {
+        return;
+    }
+
+    auto bits = xEventGroupWaitBits(event_group_, ESP_SSL_EVENT_RECEIVE_TASK_EXIT, pdFALSE, pdFALSE,
+                                    pdMS_TO_TICKS(10000));
+    if (!(bits & ESP_SSL_EVENT_RECEIVE_TASK_EXIT)) {
+        ESP_LOGE(TAG, "Failed to wait for receive task exit");
+    } else {
+        receive_task_handle_ = nullptr;
+    }
+}
